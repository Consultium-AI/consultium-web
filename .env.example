# Firebase Authentication (optioneel)
# Maak een project op https://console.firebase.google.com → Projectinstellingen → Jouw apps → Web-app
# Authentication: E-mail/wachtwoord + Google (zelfde Google-client als GIS) voor sync tussen apparaten.
# Voeg geautoriseerde domeinen toe (localhost, jouw productiedomein).
#
# Firestore (aanbevolen voor sync): Console → Firestore Database → database aanmaken (productiemodus).
# Rules → bewerk en plak inhoud van firestore.rules uit deze repo (deploy rules).
#
# GitHub Pages-build: kopieer waarden naar .env (niet committen), `gh auth login`, daarna `npm run secrets:github`.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google / Gmail-inloggen (OAuth 2.0 via Google Identity Services) — werkt zonder Firebase Auth.
# Publieke client-ID; geen client secret in de frontend.
#
# Als Google meldt: "voldoet niet aan OAuth 2.0-beleid" / registreer JavaScript-oorsprong:
# 1) https://console.cloud.google.com/apis/credentials
# 2) Open je OAuth 2.0 Client ID (type "Web application") — dezelfde ID als VITE_GOOGLE_OAUTH_CLIENT_ID.
# 3) Authorized JavaScript origins — exact toevoegen (geen pad, geen slash aan het eind):
#    - http://localhost:5174        (npm run dev; Vite staat op poort 5174)
#    - http://127.0.0.1:5174        (zelfde site via 127.0.0.1 = andere origin dan localhost)
#    - https://smartium.nl
#    - https://www.smartium.nl
# 4) Authorized redirect URIs — voor web-clients vaak ook:
#    - http://localhost:5174
#    - http://127.0.0.1:5174
#    - https://smartium.nl
#    - https://www.smartium.nl
# 5) Opslaan en enkele minuten wachten; harde refresh van de app (Ctrl+Shift+R).
#
# Alleen de OAuth "Client ID" (…apps.googleusercontent.com), niet het client secret (GOCSPX-…).
VITE_GOOGLE_OAUTH_CLIENT_ID=

# ─── Stripe (betalingen) ───
# Nooit de geheime sleutel sk_live_ / sk_test_ in .env van de frontend of in git zetten.
#
# Geheime sleutel alleen op de Cloudflare Worker:
#   cd worker && npx wrangler secret put STRIPE_SECRET_KEY
#
# Prijs-ID's (price_...): automatisch aanmaken — in worker/.dev.vars ook STRIPE_SECRET_KEY=sk_... zetten, dan:
#   cd worker && npm run stripe:setup-prices
# Uitvoer plakken in wrangler.toml [vars] of Cloudflare → Worker → Variables.
#
# Abonnement + iDEAL | Wero: Worker-var STRIPE_PAYMENT_METHOD_TYPES=ideal (default). SEPA-incasso in Stripe activeren.
#
# Publishable key pk_... (Dashboard → Developers → API keys): vereist voor ingebouwde checkout op /billing.
# Zonder deze key valt de app terug op redirect naar Stripe-hosted Checkout.
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── Worker: bevestigingsmail na Stripe (optioneel) ───
# Zet deze alleen in Cloudflare Worker → Settings → Variables (of worker/.dev.vars), niet in de Vite .env.
# Resend: https://resend.com — API key + geverifieerd afzenderdomein.
#   RESEND_API_KEY=re_...
#   RESEND_FROM=Smartium <factuur@jouwdomein.nl>
#   FEEDBACK_TO=SmartiumSupport@gmail.com   (optioneel; default in wrangler.toml)
# Feedback-knop in de app → POST /api/feedback op dezelfde Worker (geen sleutel in Vite .env).
# Zonder Resend: Stripe kan nog steeds een betaalbewijs mailen als dat in Stripe Dashboard staat (Customers → Emails).

# ─── Admin automation (server-side only) ───
# Voor script: npm run automation:export-user-access-status
# Gebruik EEN van deze opties:
# 1) FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON={...hele service-account JSON...}
# 2) GOOGLE_APPLICATION_CREDENTIALS=C:\pad\naar\service-account.json
# 3) Losse vars (zoals in worker): FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
#
# Als je "Unable to detect a Project Id" krijgt: zet FIREBASE_PROJECT_ID of vul
# VITE_FIREBASE_PROJECT_ID in .env (zelfde als frontend), of gebruik een JSON-key
# met "project_id".
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CLIENT_EMAIL=
# Let op: newline escapen als \n
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=
#
# Google Sheet vullen: npm run automation:export-user-access-to-sheets
# - Spreadsheet delen met het *service-account e-mailadres* (staat in de JSON) als Editor
# - In Google Cloud Console → APIs: "Google Sheets API" inschakelen voor hetzelfde project
# - ID uit URL: https://docs.google.com/spreadsheets/d/DIT_ID_HIER/edit
GOOGLE_SHEETS_SPREADSHEET_ID=
# Optioneel; default tabnaam "Gebruikers"
GOOGLE_SHEETS_TAB_NAME=
